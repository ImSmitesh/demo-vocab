{"componentChunkName":"component---src-components-concept-jsx","path":"/imsmitesh.github.io/demo-vocab/gsord.germania-sacra.de/resources/Benediktinerinnen.html","result":{"pageContext":{"node":{"id":"https://imsmitesh.github.io/demo-vocab/gsord.germania-sacra.de/resources/Benediktinerinnen","type":"Concept","prefLabel":{"de":"Benediktinerinnen","en":"Benedictine Nuns","la":"Ordo Sancti Benedicti","nl":"Benedictinessen","fr":null,"it":null},"altLabel":{"de":null,"en":null,"la":["OSB (w)"],"nl":null,"fr":null,"it":null},"hiddenLabel":null,"definition":{"de":"Seit dem 8. Jahrhundert wurde die Benediktregel auch den Bedürfnissen weiblicher Ordensmitglieder angepasst. Die Ursprünge der Benediktinerinnen gehen wohl auf das spätantike Mönchtum zurück. Eine Orientierung an der Regula Benedicti geschah zunächt über die Mischregel. Die karolingischen Bestrebungen zur Durchsetzung der Benediktregel, die in der Aachener Gesetzgebung von 816 manifest wurden, betrafen zwar nur Männerklöster, wirkten sich jedoch auch auf Frauenklöster aus. Anders als bei den Benediktinern blieb die kanonikale Lebensform für Frauen rechtmäßig.","en":null,"la":null,"nl":null,"fr":null,"it":null},"note":null,"changeNote":null,"editorialNote":null,"historyNote":null,"scopeNote":null,"notation":["GSReligiousOrder033"],"example":null,"narrower":[],"narrowerTransitive":[],"broader":{"id":"https://imsmitesh.github.io/demo-vocab/gsord.germania-sacra.de/resources/Orden_nach_der_Benediktregel","prefLabel":{"de":"Orden nach der Benediktregel","en":null,"la":null,"nl":null,"fr":null,"it":null}},"broaderTransitive":null,"related":[{"id":"https://imsmitesh.github.io/demo-vocab/gsord.germania-sacra.de/resources/Coelestinerinnen","prefLabel":{"de":"Coelestinerinnen","en":"Celestine Nuns","la":null,"nl":null,"fr":null,"it":null}},{"id":"https://imsmitesh.github.io/demo-vocab/gsord.germania-sacra.de/resources/Zisterzienserinnen","prefLabel":{"de":"Zisterzienserinnen","en":"Cistercian Nuns","la":"Ordo Cisterciensis",